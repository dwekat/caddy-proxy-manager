{
  "name": "caddy-proxy-manager",
  "version": "1.0.0",
  "description": "A CLI tool to manage local reverse proxies using Caddy",
  "type": "module",
  "main": "src/cli.js",
  "bin": {
    "cpm": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js",
    "dev": "nodemon src/cli.js",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test": "jest"
  },
  "keywords": [
    "caddy",
    "proxy",
    "manager",
    "cli",
    "reverse-proxy",
    "local-development"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^11.1.0",
    "js-yaml": "^4.1.1",
    "ora": "^7.0.1",
    "shelljs": "^0.8.5",
    "sudo-prompt": "^9.2.1"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.7.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
